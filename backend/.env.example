# Copy to backend/.env for local development or configure these in Render.
# For Render, keep secrets only in the dashboard Environment tab.
# Supabase shared pooler example:
# postgresql://postgres.PROJECT_REF:YOUR_DATABASE_PASSWORD@aws-1-ap-south-1.pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql://postgres.PROJECT_REF:YOUR_DATABASE_PASSWORD@aws-1-ap-south-1.pooler.supabase.com:6543/postgres
JWT_SECRET=replace_with_a_long_random_secret_at_least_32_chars
APP_ENV=development
ACCESS_TOKEN_MINUTES=30
REFRESH_TOKEN_DAYS=30
PASSWORD_HASH_ROUNDS=12
CORS_ORIGINS=http://localhost:19006,http://127.0.0.1:19006,http://localhost:8081,http://127.0.0.1:8081,https://your-frontend.example.com
ENABLE_DEMO_SEED_DATA=true
# Optional: strict certificate verification for asyncpg
ASYNCPG_STRICT_SSL=false
# Optional only if you later add Supabase admin SDK usage on the backend:
# SUPABASE_URL=https://PROJECT_REF.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
