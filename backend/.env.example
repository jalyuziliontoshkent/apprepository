# Copy to backend/.env for local development or configure these in Render.
DATABASE_URL=postgresql://postgres.PROJECTREF:ENCODED_PASSWORD@aws-0-ap-south-1.pooler.supabase.com:6543/postgres
JWT_SECRET=replace_with_a_long_random_secret
APP_ENV=development
ACCESS_TOKEN_MINUTES=30
REFRESH_TOKEN_DAYS=30
PASSWORD_HASH_ROUNDS=12
CORS_ORIGINS=http://localhost:19006,http://127.0.0.1:19006,http://localhost:8081,http://127.0.0.1:8081
ENABLE_DEMO_SEED_DATA=true
# Optional: strict certificate verification for asyncpg
ASYNCPG_STRICT_SSL=false
